# Convex - get from https://dashboard.convex.dev
NEXT_PUBLIC_CONVEX_URL=

# Composio - get from https://platform.composio.dev/settings
COMPOSIO_API_KEY=

# Google AI - for chat (Gemini). Get from https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=

# Langfuse - LLM observability, tracing, debugging. Optional.
# Get from https://cloud.langfuse.com
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# Clerk - auth. Optional: Clerk runs in keyless mode without these.
# Get from https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
